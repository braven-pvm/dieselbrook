@model AddressModel
@{
    var pageUrl = httpContextAccessor.HttpContext.Request.Path.ToString();
}
<input class="address-id" asp-for="Id" type="hidden" />
<div class="edit-address">
    <div class="inputs half-width">
        <label asp-for="FirstName" asp-postfix=":"></label>
        <input asp-for="FirstName" />
        <nop-required />
        <span asp-validation-for="FirstName"></span>
    </div>
    <div class="inputs half-width">
        <label asp-for="LastName" asp-postfix=":"></label>
        <input asp-for="LastName" />
        <nop-required />
        <span asp-validation-for="LastName"></span>
    </div>
    <div class="inputs half-width">
        <label asp-for="Email" asp-postfix=":"></label>
        <input asp-for="Email" />
        <nop-required />
        <span asp-validation-for="Email"></span>
    </div>
    @if (Model.CompanyEnabled)
    {
        <div class="inputs half-width">
            <label asp-for="Company" asp-postfix=":"></label>
            <input asp-for="Company" />
            @if (Model.CompanyRequired)
            {
                <nop-required />
            }
            <span asp-validation-for="Company"></span>
        </div>
    }
    @if (Model.CountryEnabled)
    {
        <div class="inputs half-width">
            <label asp-for="CountryId" asp-postfix=":"></label>
            <select asp-for="CountryId" asp-items="Model.AvailableCountries"
                    data-trigger="country-select"
                    data-url="@(Url.RouteUrl("GetStatesByCountryId"))"
                    data-stateprovince="#@Html.IdFor(model => model.StateProvinceId)"
                    data-loading="#states-loading-progress"></select>
            <nop-required />
            <span asp-validation-for="CountryId"></span>
        </div>
    }
    @if (Model.CountryEnabled && Model.StateProvinceEnabled)
    {
        <div class="inputs half-width">
            <label asp-for="StateProvinceId" asp-postfix=":"></label>
            <select asp-for="StateProvinceId" asp-items="Model.AvailableStates"
                    data-trigger="state-select">
            </select>
            <span id="states-loading-progress" style="display: none;" class="please-wait">@T("Common.Wait")</span>
            <span asp-validation-for="StateProvinceId"></span>
        </div>
    }

    @if (pageUrl == Url.RouteUrl("CustomerAddressEdit"))
    {
        <div class="inputs search-box-state">
            <label for="provinces" asp-postfix=":">@T("Annique.Plugin.ShippingAddressValidation.Field.SubrubPostalCodeCombination")</label>
            <input type="text" class="search-box-text" id="small-provincessearchterms" autocomplete="off" name="q" placeholder="@T("Search.SearchBox.Province")" aria-label="@T("Search.SearchBox.Text.Province")" />
        </div>
    }
    else
    {
        <div class="inputs search-box-state">
            <label for="provinces" asp-postfix=":">@T("Annique.Plugin.ShippingAddressValidation.Field.SubrubPostalCodeCombination")</label>
            <input type="text" class="search-box-text" id="small-provincessearchterms" autocomplete="off" name="q" placeholder="@T("Search.SearchBox.Province")" aria-label="@T("Search.SearchBox.Text.Province")" required />
            <nop-required />
        </div>
    }

    @if (Model.CityEnabled)
    {
        <div class="inputs half-width">
            <label asp-for="City" asp-postfix=":"></label>
            <input asp-for="City" />
            @if (Model.CityRequired)
            {
                <nop-required />
            }
            <span asp-validation-for="City"></span>
        </div>
    }
    @if (Model.CountyEnabled)
    {
        <div class="inputs half-width">
            <label asp-for="County" asp-postfix=":"></label>
            <input asp-for="County" />
            @if (Model.CountyRequired)
            {
                <nop-required />
            }
            <span asp-validation-for="County"></span>
        </div>
    }
    @if (Model.StreetAddressEnabled)
    {
        <div class="inputs half-width">
            <label asp-for="Address1" asp-postfix=":"></label>
            <input asp-for="Address1" />
            @if (Model.StreetAddressRequired)
            {
                <nop-required />
            }
            <span asp-validation-for="Address1"></span>
        </div>
    }
    @if (Model.StreetAddress2Enabled)
    {
        <div class="inputs half-width">
            <label asp-for="Address2" asp-postfix=":"></label>
            <input asp-for="Address2" />
            @if (Model.StreetAddress2Required)
            {
                <nop-required />
            }
            <span asp-validation-for="Address2"></span>
        </div>
    }
    @if (Model.ZipPostalCodeEnabled)
    {
        <div class="inputs half-width">
            <label asp-for="ZipPostalCode" asp-postfix=":"></label>
            <input asp-for="ZipPostalCode" />
            @if (Model.ZipPostalCodeRequired)
            {
                <nop-required />
            }
            <span asp-validation-for="ZipPostalCode"></span>
        </div>
    }
    @if (Model.PhoneEnabled)
    {
        <div class="inputs half-width">
            <label asp-for="PhoneNumber" asp-postfix=":"></label>
            <input asp-for="PhoneNumber" />
            @if (Model.PhoneRequired)
            {
                <nop-required />
            }
            <span asp-validation-for="PhoneNumber"></span>
        </div>
    }
    @if (Model.FaxEnabled)
    {
        <div class="inputs half-width">
            <label asp-for="FaxNumber" asp-postfix=":"></label>
            <input asp-for="FaxNumber" />
            @if (Model.FaxRequired)
            {
                <nop-required />
            }
            <span asp-validation-for="FaxNumber"></span>
        </div>
    }
    @await Component.InvokeAsync(typeof(WidgetViewComponent), new { widgetZone = PublicWidgetZones.AddressBottom, additionalData = Model })
</div>


<script asp-location="Footer">
    $(document).ready(function () {
        $('#@Html.IdFor(model => model.City)').bind('keypress keydown keyup', function (e) {
            e.preventDefault();
        });

        $('#@Html.IdFor(model => model.ZipPostalCode)').bind('keypress keydown keyup', function (e) {
            e.preventDefault();
        });

        $("#small-provincessearchterms").on("change", function () {
            var subrubvalue = document.getElementById("small-provincessearchterms").value;
            if (subrubvalue.includes("(")) {
                var getSplitSubrubValue = subrubvalue.split('(');
                document.getElementById('@Html.IdFor(model => model.City)').value = getSplitSubrubValue[0];
                document.getElementById('@Html.IdFor(model => model.ZipPostalCode)').value = subrubvalue.split('(')[1].split(' - ')[1].split(')')[0];
            }
        });

        $("#@Html.IdFor(model => model.StateProvinceId)").on("change", function () {
            $("#small-provincessearchterms").val('');
            $("#@Html.IdFor(model => model.City)").val('');
            $("#@Html.IdFor(model => model.ZipPostalCode)").val('');
        });

        var showLinkToResultSearch;
        var searchText;
        $('#small-provincessearchterms').autocomplete({
            delay: 300,
            source: function (request, response) {
                var stateId = $("#@Html.IdFor(model => model.StateProvinceId)").children("option:selected").val();
                $.ajax({
                    url: '@(Url.RouteUrl("ProvinceSearchAutoComplete"))',
                    dataType: "json",
                    data: {
                        term: request.term,
                        stateId: stateId
                    },
                    success: function (data) {
                        response(data);
                    }
                });
            },
            appendTo: '.search-box-state',
            select: function (event, ui) {
                $("#small-provincessearchterms").val(ui.item.label);
                var subrubvalue = $("#small-provincessearchterms").val();
                if (subrubvalue.includes("(")) {
                    var getSplitSubrubValue = subrubvalue.split('(');
                    document.getElementById('@Html.IdFor(model => model.City)').value = getSplitSubrubValue[0];
                    document.getElementById('@Html.IdFor(model => model.ZipPostalCode)').value = subrubvalue.split('(')[1].split(' - ')[1].split(')')[0];
                }
                return false;
            }
        })
            .data("ui-autocomplete")._renderItem = function (ul, item) {
                var t = item.label;
                //html encode
                t = htmlEncode(t);

                var subrubvalue = document.getElementById("small-provincessearchterms").value;

                return $("<li></li>")
                    .data("item.autocomplete", item)
                    .append("<a><span>" + t + "</span></a>")
                    .appendTo(ul);
            };
    });
</script>

