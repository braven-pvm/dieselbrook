@model SearchBoxModel

@if (Model.ShowSearchBox)
{
    <div class="responsive-nav-head">
        <span class="text">@T("Search")</span>
        <span class="button close-search"></span>
    </div>
    <div class="responsive-nav-body">
        <form asp-route="ProductSearch" method="get" class="search-form" id="small-search-box-form">
            <input type="text" class="search-box-text" id="small-searchterms" autocomplete="off" name="q" placeholder="@T("Search.SearchBox.Tooltip")" aria-label="@T("Search.SearchBox.Text.Label")" />
           
            @*   Task 613 full text search  *@
            @await Component.InvokeAsync("SearchOptionSelector")

            @await Component.InvokeAsync(typeof(WidgetViewComponent), new { widgetZone = PublicWidgetZones.SearchBoxBeforeSearchButton, additionalData = Model })
            <button type="submit" class="button-1 search-box-button">@T("Search.Button")</button>
            @if (Model.SearchTermMinimumLength > 0)
            {
                <script asp-location="Footer">
                    $("#small-search-box-form").on("submit", function(event) {
                        if ($("#small-searchterms").val() == "") {
                            alert('@Html.Raw(JavaScriptEncoder.Default.Encode(T("Search.EnterSearchTerms").Text))');
                            $("#small-searchterms").focus();
                            event.preventDefault();
                        }
                    });
                </script>
            }
            @if (Model.AutoCompleteEnabled)
            {
                <script asp-location="Footer">
                    $(document).ready(function () {

                        var showLinkToResultSearch;
                        var searchText;

                        $('#small-searchterms').autocomplete({
                            delay: 500,
                            minLength: @(Model.SearchTermMinimumLength.ToString()),
                            source: function (request, response) {
                                var selectedSearchOption = "";

                                // Check if any input[name="searchOption"] exists before accessing its value
                                if ($('input[name="searchOption"]').length > 0) {
                                    selectedSearchOption = $('input[name="searchOption"]:checked').val() || "";
                                }

                                //Task 613 full text serach send ajax call to annique catalog controller
                                $.ajax({
                                    url: '@(Url.RouteUrl("ProductSearchAutoComplete"))',
                                    dataType: "json",
                                    data: {
                                        term: request.term,
                                        searchOption: selectedSearchOption
                                    },
                                    success: function (data) {
                                        response(data);
                                    }
                                });
                            },
                            appendTo: '.search-box',
                            select: function (event, ui) {
                                $("#small-searchterms").val(ui.item.label);
                                setLocation(ui.item.producturl);
                                return false;
                            },
                            open: function (event, ui) {
                                if (showLinkToResultSearch) {
                                    searchText = document.getElementById("small-searchterms").value;

                                    var selectedSearchOption = "";
                                    var optionQuery = "";

                                    //customized this code to include searchOption in url
                                    if ($('input[name="searchOption"]').length > 0) {
                                        selectedSearchOption = $('input[name="searchOption"]:checked').val() || "";
                                        optionQuery = "&searchOption=" + encodeURIComponent(selectedSearchOption);
                                    }

                                    $(".ui-autocomplete").append(
                                        "<li class=\"ui-menu-item\" role=\"presentation\">" +
                                        "<a href=\"/search?q=" + encodeURIComponent(searchText) + optionQuery + "\">" +
                                        "@T("Search.SearchBox.SearchPageLink")</a></li>"
                                    );
                                }
                            }
                        })
                        .data("ui-autocomplete")._renderItem = function (ul, item) {
                            var t = item.label;
                            showLinkToResultSearch = item.showlinktoresultsearch;
                            t = htmlEncode(t);

                            return $("<li></li>")
                                .data("item.autocomplete", item)
                                .append("<a>@(Model.ShowProductImagesInSearchAutoComplete ? Html.Raw("<img class='ui-menu-item-image' src='\" + item.productpictureurl + \"'>") : null)<span class=\"ui-menu-item-text\">" + t + "</span></a>")
                                .appendTo(ul);
                        };

                        // Re-trigger autocomplete if search option changes
                        $('input[name="searchOption"]').on('change', function () {
                            var currentTerm = $('#small-searchterms').val();
                            if (currentTerm.length >= @(Model.SearchTermMinimumLength)) {
                                $('#small-searchterms').autocomplete('search', currentTerm);
                            }
                        });
                    });
                </script>

            }
            @await Component.InvokeAsync(typeof(WidgetViewComponent), new { widgetZone = PublicWidgetZones.SearchBox, additionalData = Model })
        </form>
    </div>
}