@model CustomShippingRuleSearchModel
@inject Nop.Services.Stores.IStoreService storeService
@{
    Layout = "_AdminLayout";
}

@{
    //page title
    ViewBag.PageTitle = T("Annique.Plugin.Nop.Customization.CustomShippingRule").Text;
    //active menu item (system name)
    NopHtml.SetActiveMenuItemSystemName("Annique.Plugin.Nop.Customization.CustomShippingRule");
}
@{
    var stores = await storeService.GetAllStoresAsync();
}
<div class="content-header clearfix">
    <h1 class="float-left">
        @T("Annique.Plugin.Nop.Customization.CustomShippingRule")
    </h1>
    <div class="float-right">
        <a asp-action="Create" class="btn bg-blue">
            <i class="fas fa-plus-square"></i>
            @T("Admin.Configuration.CustomShippingRule.AddNew")
        </a>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="form-horizontal">
            <div class="card-group">
                <div class="card card-default">
                    <div class="card-body">
                        @await Html.PartialAsync("Table", new DataTablesModel
                        {
                            Name = "report-grid",
                            UrlRead = new DataUrl("List", "AdminCustomShippingRule", null),
                            UrlDelete = new DataUrl("CustomRuleDelete", "AdminCustomShippingRule", null),
                            Length = Model.PageSize,
                            LengthMenu = Model.AvailablePageSizes,
                            ColumnCollection = new List<ColumnProperty>
                        {
                        new ColumnProperty(nameof(CustomShippingRuleModel.StoreName))
                        {
                        Title = T("Plugins.Shipping.FixedByWeightByTotal.Fields.Store").Text,
                        Width = "200",
                        Visible = stores.Count > 1
                        },
                        new ColumnProperty(nameof(CustomShippingRuleModel.CustomerRoles))
                        {
                        Title = T("Admin.Customers.Customers.Fields.CustomerRoles").Text,
                        Width = "200"
                        },
                        new ColumnProperty(nameof(CustomShippingRuleModel.CountryName))
                        {
                        Title = T("Plugins.Shipping.FixedByWeightByTotal.Fields.Country").Text,
                        Width = "200"
                        },
                        new ColumnProperty(nameof(CustomShippingRuleModel.ShippingMethodName))
                        {
                        Title = T("Plugins.Shipping.FixedByWeightByTotal.Fields.ShippingMethod").Text,
                        Width = "200"
                        },
                        new ColumnProperty(nameof(CustomShippingRuleModel.DataHtml))
                        {
                        Title = T("Plugins.Shipping.FixedByWeightByTotal.Fields.DataHtml").Text,
                        Width = "400",
                        Encode = false
                        },
                        new ColumnProperty(nameof(CustomShippingRuleModel.Id))
                        {
                        Title = T("Admin.Common.Edit").Text,
                        ClassName = NopColumnClassDefaults.Button,
                        Width = "100",
                        Render = new RenderButtonEdit(new DataUrl("~/Admin/AdminCustomShippingRule/Edit/"))
                        },
                        new ColumnProperty(nameof(CustomShippingRuleModel.Id))
                        {
                        Title = T("Admin.Common.Delete").Text,
                        ClassName = NopColumnClassDefaults.Button,
                        Render = new RenderButtonRemove(T("Admin.Common.Delete").Text),
                        Width = "100"
                        }
                        }
                        })
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>