@model ReportParameterModel

@if (Model.Id > 0)
{
    <div class="card-body">
    @await Html.PartialAsync("Table", new DataTablesModel
    {
        Name = "parameterValue-grid",
        UrlRead = new DataUrl("ParameterValueList", "AdminAnniqueReport", new RouteValueDictionary { [nameof(Model.ReportParameterValueSearchModel.ReportParameterId)] = Model.ReportParameterValueSearchModel.ReportParameterId }),
        UrlDelete = new DataUrl("ParameterValueDelete", "AdminAnniqueReport", null),
        Length = Model.ReportParameterValueSearchModel.PageSize,
        LengthMenu = Model.ReportParameterValueSearchModel.AvailablePageSizes,
        ColumnCollection = new List<ColumnProperty>
        {
            new ColumnProperty(nameof(ReportParameterValueModel.Name))
            {
                Title = T("Admin.ReportParameterValue.Fields.Name").Text,
                Width = "200"
            },
            new ColumnProperty(nameof(ReportParameterValueModel.DisplayOrder))
            {
                Title = T("Admin.ReportParameterValue.Fields.DisplayOrder").Text,
                Width = "10",
                ClassName = NopColumnClassDefaults.CenterAll,
            },
            new ColumnProperty(nameof(ReportParameterValueModel.IsPreSelected))
            {
                Title = T("Admin.ReportParameterValue.Fields.IsPreSelected").Text,
                Width = "100",
                ClassName =  NopColumnClassDefaults.CenterAll,
                Render = new RenderBoolean()
            },
            new ColumnProperty(nameof(ReportParameterValueModel.Id))
            {
                Title = T("Admin.Common.Edit").Text,
                Width = "100",
                ClassName =  NopColumnClassDefaults.Button,
                Render = new RenderCustom("renderParameterValueDetails")
            },
            new ColumnProperty(nameof(ReportParameterValueModel.Id))
            {
                Title = T("Admin.Common.Delete").Text,
                Width = "100",
                Render = new RenderButtonRemove(T("Admin.Common.Delete").Text),
                ClassName = NopColumnClassDefaults.Button
            }
        }
    })
        <script>
            function renderParameterValueDetails(data, type, row, meta) {
                return '<button onclick=\"javascript:OpenWindow(\'@Url.Content("~/Admin/AdminAnniqueReport/ParameterValueEdit/")' + data + '?btnId=btnRefreshValue&formId=parameter-form\', 800, 700, true); return false;\" class="btn btn-default"><i class="fas fa-pencil-alt"></i>@T("Admin.Common.Edit")</button>';
            }
        </script>
    </div>
    <div class="card-footer">
        <button type="submit" id="btnAddNewParameterValue"
            onclick="javascript:OpenWindow('@(Url.Action("ParameterValueCreate", "AdminAnniqueReport", new { reportParameterId = Model.Id, btnId = "btnRefreshValue", formId = "parameter-form" }))', 800, 800, true); return false;"
            class="btn bg-blue">
            <i class="fas fa-plus-square"></i>
            @T("Admin.Configuration.AnniqueReports.ParameterValues.AddNew")
        </button>
        <input type="submit" id="btnRefreshValue" style="display: none" />
        <script>
            $(document).ready(function () {
                $('#btnRefreshValue').click(function () {
                    //refresh grid
                    updateTable('#parameterValue-grid');

                    //return false to don't reload a page
                    return false;
                });
            });
        </script>
    </div>
}
else
{
    <div class="card-body">
        @T("Admin.Configuration.AnniqueReports.ParameterValues.SaveBeforeEdit")
    </div>
}