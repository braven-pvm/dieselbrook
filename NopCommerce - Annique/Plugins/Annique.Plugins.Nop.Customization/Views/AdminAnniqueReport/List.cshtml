@model ReportSearchModel

@{
    Layout = "_AdminLayout";
}

@{
    //page title
    ViewBag.PageTitle = T("Annique.Plugin.Nop.Customization.Report").Text;
    //active menu item (system name)
    NopHtml.SetActiveMenuItemSystemName("Annique.Plugin.Nop.Customization.Report");
}

<div class="content-header clearfix">
    <h1 class="float-left">
        @T("Annique.Plugin.Nop.Customization.Report")
    </h1>
    <div class="float-right">
        <a asp-action="Create" class="btn bg-blue">
            <i class="fas fa-plus-square"></i>
            @T("Admin.Configuration.AnniqueReports.AddNew")
        </a>
    </div>
</div>

<section class="content">
    <div class="container-fluid">
        <div class="form-horizontal">
            <div class="card-group">
                <div class="card card-default">
                    <div class="card-body">
                        @await Html.PartialAsync("Table", new DataTablesModel
                        {
                            Name = "report-grid",
                            UrlRead = new DataUrl("List", "AdminAnniqueReport", null),
                            UrlDelete = new DataUrl("ReportDelete", "AdminAnniqueReport", null),
                            Length = Model.PageSize,
                            LengthMenu = Model.AvailablePageSizes,
                            ColumnCollection = new List<ColumnProperty>
                            {
                                new ColumnProperty(nameof(ReportModel.Name))
                                {
                                    Title = T("Admin.AnniqueReport.Fields.Name").Text,
                                    //show custom text instead of report name task 633
                                    Render = new RenderCustom("function(data, type, row, meta) { return row.CustomText ? row.CustomText : row.Name; }")
                                },
                                new ColumnProperty(nameof(ReportModel.Published))
                                {
                                    Title = T("Admin.AnniqueReport.Fields.Published").Text,
                                    Width = "100",
                                    ClassName =  NopColumnClassDefaults.CenterAll,
                                    Render = new RenderBoolean()
                                },
                                new ColumnProperty(nameof(ReportModel.DisplayOrder))
                                {
                                    Title = T("Admin.AnniqueReport.Fields.DisplayOrder").Text
                                },
                                new ColumnProperty(nameof(ReportModel.Id))
                                {
                                    Title = T("Admin.Common.Edit").Text,
                                    Width = "100",
                                    ClassName =  NopColumnClassDefaults.Button,
                                    Render = new RenderButtonEdit(new DataUrl("~/Admin/AdminAnniqueReport/Edit/"))
                                },
                                new ColumnProperty(nameof(ReportModel.Id))
                                {
                                    Title = T("Admin.Common.Delete").Text,
                                    Width = "100",
                                    Render = new RenderButtonRemove(T("Admin.Common.Delete").Text),
                                    ClassName = NopColumnClassDefaults.Button
                                }
                            }
                        })
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>