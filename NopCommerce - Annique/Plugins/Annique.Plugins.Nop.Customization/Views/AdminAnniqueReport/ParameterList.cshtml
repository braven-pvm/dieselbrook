@model ReportModel

@if (Model.Id > 0)
{
    <div class="card-body">
        @await Html.PartialAsync("Table", new DataTablesModel
        {
            Name = "parameter-grid",
            UrlRead = new DataUrl("ParameterList", "AdminAnniqueReport", new RouteValueDictionary { [nameof(Model.ReportParameterSearchModel.ReportId)] = Model.ReportParameterSearchModel.ReportId }),
            UrlDelete = new DataUrl("ParameterDelete", "AdminAnniqueReport", null),
            Length = Model.ReportParameterSearchModel.PageSize,
            LengthMenu = Model.ReportParameterSearchModel.AvailablePageSizes,
            ColumnCollection = new List<ColumnProperty>
            {
                new ColumnProperty(nameof(ReportParameterModel.Name))
                {
                    Title = T("Admin.ReportParameter.Fields.Name").Text,
                    Width = "200"
                },
                new ColumnProperty(nameof(ReportParameterModel.DisplayOrder))
                {
                    Title = T("Admin.ReportParameter.Fields.DisplayOrder").Text,
                    Width = "50",
                    ClassName = NopColumnClassDefaults.CenterAll,
                },
                new ColumnProperty(nameof(ReportParameterModel.Id))
                {
                    Title = T("Admin.Common.Edit").Text,
                    Width = "100",
                    ClassName =  NopColumnClassDefaults.Button,
                    Render = new RenderCustom("renderParameterDetails")
                },
                new ColumnProperty(nameof(ReportParameterModel.Id))
                {
                    Title = T("Admin.Common.Delete").Text,
                    Width = "100",
                    Render = new RenderButtonRemove(T("Admin.Common.Delete").Text),
                    ClassName = NopColumnClassDefaults.Button
                }
            }
        })
        <script>
        function renderParameterDetails(data, type, row, meta) {
            return '<button onclick=\"javascript:OpenWindow(\'@Url.Content("~/Admin/AdminAnniqueReport/ParameterEdit/")' + data + '?btnId=btnRefreshParameters&formId=report-form\', 800, 700, true); return false;\" class="btn btn-default"><i class="fas fa-pencil-alt"></i>@T("Admin.Common.Edit")</button>';
        }
        </script>
    </div>
    <div class="card-footer">
        <button type="submit" id="btnAddNewParameter"
            onclick="javascript:OpenWindow('@(Url.Action("ParameterCreate", "AdminAnniqueReport", new { reportId = Model.Id, btnId = "btnRefreshParameters", formId = "report-form" }))', 800, 800, true); return false;"
                class="btn bg-blue">
            <i class="fas fa-plus-square"></i>
            @T("Admin.Configuration.AnniqueReports.Parameters.AddNew")
        </button>
        <input type="submit" id="btnRefreshParameters" style="display: none" />
        <script>
            $(document).ready(function () {
                $('#btnRefreshParameters').click(function () {
                    //refresh grid
                    updateTable('#parameter-grid');

                    //return false to don't reload a page
                    return false;
                });
            });
        </script>
    </div>
}
else
{
    <div class="card-body">
        @T("Admin.Configuration.AnniqueReports.Parameters.SaveBeforeEdit")
    </div>
}