@model CustomCategoryTabInfoModel

@{
    var customer = await workContext.GetCurrentCustomerAsync();

    const string hideCategoryIntregration = "Configure.HideInfoBlock";
    var hideCategoryIntregrationInfoBlock = await genericAttributeService.GetAttributeAsync<bool>(customer, hideCategoryIntregration);

    NopHtml.SetActiveMenuItemSystemName("Categories");
}

<nop-card asp-name="customcategoryintegration-info" asp-icon="fas fa-th-list" asp-title="@T("Admin.Catalog.Category.CategoryIntegration.IntegrationTab")" asp-hide-block-attribute-name="@hideCategoryIntregration" asp-hide="@hideCategoryIntregrationInfoBlock" asp-advanced="false">
    @if (Model.CategoryIntegrationModel.CategoryId > 0)
    {
        <div class="card-body">
            @await Html.PartialAsync("Table", new DataTablesModel
        {
        Name = "categoryIntegration-grid",
        UrlRead = new DataUrl("CategoryIntegrationList", "AdminCategoryIntegration", new RouteValueDictionary { [nameof(Model.CategoryIntegrationSearchModel.CategoryId)] = Model.CategoryIntegrationSearchModel.CategoryId }),
        UrlDelete = new DataUrl("CategoryIntegrationDelete", "AdminCategoryIntegration", null),
        Length = Model.CategoryIntegrationSearchModel.PageSize,
        LengthMenu = Model.CategoryIntegrationSearchModel.AvailablePageSizes,
        ColumnCollection = new List<ColumnProperty>
        {
        new ColumnProperty(nameof(CategoryIntegrationModel.IntegrationField))
        {
        Title = T("Admin.Catalog.Category.CategoryIntegration.Fields.IntegrationField").Text
        },
        new ColumnProperty(nameof(CategoryIntegrationModel.IntegrationValue))
        {
        Title = T("Admin.Catalog.Category.CategoryIntegration.Fields.IntegrationValue").Text
        },
        new ColumnProperty(nameof(CategoryIntegrationModel.Id))
        {
        Title = T("Admin.Common.Delete").Text,
        Width = "150",
        Render = new RenderButtonRemove(T("Admin.Common.Delete").Text),
        ClassName = NopColumnClassDefaults.Button
        }
        }
        })

            <div class="card card-default">
                <div class="card-header">
                    @T("Admin.Catalog.Category.CategoryIntegration.AddNew")
                </div>
                <div class="card-body">
                    <script>
                        $(document).ready(function () {
                            $('#addCategoryIntegration').click(function () {
                                var categoryId = $("#@Html.IdFor(model => model.CategoryIntegrationModel.CategoryId)").val();
                                var integrationField = $("#@Html.IdFor(model => model.CategoryIntegrationModel.IntegrationField)").val();
                                var integrationValue = $("#@Html.IdFor(model => model.CategoryIntegrationModel.IntegrationValue)").val();

                                if (integrationField == "") {
                                    $("#categoryIntregrationFieldAlert").click();
                                    return;
                                }

                                if (integrationValue == "") {
                                    $("#categoryIntregrationValueAlert").click();
                                    return;
                                }

                                $('#addCategoryIntegration').attr('disabled', true);

                                var postData = {
                                    categoryId: categoryId,
                                    integrationField: integrationField,
                                    integrationValue: integrationValue
                                };
                                addAntiForgeryToken(postData);

                                $.ajax({
                                    cache: false,
                                    type: "POST",
                                    url: "@(Url.Action("CategoryIntegrationAdd", "AdminCategoryIntegration"))",
                                    data: postData,
                                    success: function (data, textStatus, jqXHR) {
                                        if (!data.Result) {
                                            return;
                                        }
                                        $("#@Html.IdFor(model => model.CategoryIntegrationModel.IntegrationField)").val("");
                                        $("#@Html.IdFor(model => model.CategoryIntegrationModel.IntegrationValue)").val("");
                                        updateTable('#categoryIntegration-grid');
                                    },
                                    error: function (jqXHR, textStatus, errorThrown) {
                                        $("#categoryIntregrationAddAlert").click();
                                    },
                                    complete: function (jqXHR, textStatus) {
                                        $('#addCategoryIntegration').attr('disabled', false);
                                    }
                                });
                            });
                        });
                    </script>
                    <input type="hidden" asp-for="CategoryIntegrationModel.CategoryId">
                    <div class="form-group row">
                        <div class="col-md-3">
                            <nop-label asp-for="CategoryIntegrationModel.IntegrationField" />
                        </div>
                        <div class="col-md-9">
                            <nop-editor asp-for="CategoryIntegrationModel.IntegrationField" />

                        </div>
                    </div>
                    <div class="form-group row">
                        <div class="col-md-3">
                            <nop-label asp-for="CategoryIntegrationModel.IntegrationValue" />
                        </div>
                        <div class="col-md-9">
                            <nop-editor asp-for="CategoryIntegrationModel.IntegrationValue" />
                        </div>
                    </div>

                    <div class="form-group row">
                        <div class="col-md-9 offset-md-3">
                            <button type="button" id="addCategoryIntegration" class="btn btn-primary">@T("Admin.Catalog.Category.CategoryIntegration.AddButton")</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="card-body">
            @T("Admin.Catalog.Categories.IntegrationValues.SaveBeforeEdit")
        </div>
    }
</nop-card>
<nop-alert asp-alert-id="categoryIntregrationFieldAlert" asp-alert-message="@T("Admin.Catalog.Category.CategoryIntegration.Fields.IntegrationField.Required")" />
<nop-alert asp-alert-id="categoryIntregrationValueAlert" asp-alert-message="@T("Admin.Catalog.Category.CategoryIntegration.Fields.IntegrationValue.Required")" />
<nop-alert asp-alert-id="categoryIntregrationAddAlert" asp-alert-message="@T("Admin.Catalog.Category.CategoryIntegration.Alert.CategoryIntegrationAdd")" />