@model RegistrationPageSettingsModel

@{
    Layout = "_AdminLayout";
}

@{
    //page title
    ViewBag.PageTitle = T("Annique.Plugin.Nop.Customization.RegistrationPageSettings").Text;
    //active menu item (system name)
    NopHtml.SetActiveMenuItemSystemName("Annique.Plugin.Nop.Customization.RegistrationPageSettings");

    const string hideInfoBlockAttributeName = "InfoPage.HideInfoBlock";
    var hideInfoBlock = await genericAttributeService.GetAttributeAsync<bool>(await workContext.GetCurrentCustomerAsync(), hideInfoBlockAttributeName);

}

<form asp-controller="AnniqueCustomization" asp-action="RegistrationPageSetting" method="post" id="register-form">
    <div class="content-header clearfix">
        <h1 class="float-left">
            @T("Annique.Plugin.Nop.Customization.RegistrationPageSettings")
        </h1>
        <div class="float-right">
            <button type="submit" name="save" class="btn bg-blue">
                <i class="far fa-save"></i>
                @T("Admin.Common.Save")
            </button>
        </div>
    </div>

    <div asp-validation-summary="All"></div>
    <input asp-for="Id" type="hidden" />

    <section class="content">
        <div class="container-fluid">
            <div class="form-horizontal">
                <nop-cards id="report-panels">
                    <nop-card asp-name="setting-info" asp-icon="fas fa-info" asp-title="@T("Annique.Plugin.Nop.Customization.RegistrationPageSettings")" asp-hide-block-attribute-name="@hideInfoBlockAttributeName" asp-hide="@hideInfoBlock" asp-advanced="false">

                        <div class="card-body">
                            <div class="form-group row">
                                <div class="col-md-3">
                                    <nop-label asp-for="CustomCSS" />
                                </div>
                                <div class="col-md-9">
                                    <nop-textarea asp-for="CustomCSS" class="style-text" />
                                </div>
                            </div>
                        </div>

                        <div class="card-body">
                            <div class="form-group row">
                                <div class="col-md-3">
                                    <nop-label asp-for="CustomJS" />
                                </div>
                                <div class="col-md-9">
                                    <nop-textarea asp-for="CustomJS" class="style-text" />
                                </div>
                            </div>
                        </div>

                        <div class="card-body">
                            <div class="form-group row">
                            <div class="col-md-3">
                                <nop-label asp-for="TopSectionPublished" />
                            </div>
                            <div class="col-md-9">
                                <nop-editor asp-for="TopSectionPublished" />
                            </div>
                        </div>

                        <div class="form-group row">
                            <div class="col-md-3">
                                <nop-label asp-for="TopSectionBody" />
                            </div>
                            <div class="col-md-9">
                                    <nop-textarea asp-for="TopSectionBody" class="style-text" />
                            </div>
                        </div>

                            <div class="form-group row">
                                <div class="col-md-3">
                                    <nop-label asp-for="LeftSectionPublished" />
                                </div>
                                <div class="col-md-9">
                                    <nop-editor asp-for="LeftSectionPublished" />
                                </div>
                            </div>

                            <div class="form-group row">
                                <div class="col-md-3">
                                    <nop-label asp-for="LeftSectionBody" />
                                </div>
                                <div class="col-md-9">
                                    <nop-textarea asp-for="LeftSectionBody" class="style-text" />
                                </div>
                            </div>

                            <div class="form-group row">
                                <div class="col-md-3">
                                    <nop-label asp-for="BottomSectionPublished" />
                                </div>
                                <div class="col-md-9">
                                    <nop-editor asp-for="BottomSectionPublished" />
                                </div>
                            </div>

                            <div class="form-group row">
                                <div class="col-md-3">
                                    <nop-label asp-for="BottomSectionBody" />
                                </div>
                                <div class="col-md-9">
                                    <nop-textarea asp-for="BottomSectionBody" class="style-text" />
                                </div>
                            </div>

                        </div>
                    </nop-card>
                </nop-cards>
            </div>
        </div>
    </section>
</form>

