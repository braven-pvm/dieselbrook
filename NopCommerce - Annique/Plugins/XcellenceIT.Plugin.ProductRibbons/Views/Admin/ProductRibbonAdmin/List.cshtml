@model ProductRibbonSearchModel

@{
    Layout = "_AdminLayout";
    NopHtml.SetActiveMenuItemSystemName("Plugin.ProductRibbons.List");
}

@{
    const string hideSearchBlockAttributeName = "ManufacturersPage.HideSearchBlock";
    var hideSearchBlock = await genericAttributeService.GetAttributeAsync<bool>(await workContext.GetCurrentCustomerAsync(), hideSearchBlockAttributeName);
}

<div class="content-header clearfix">
    <h1 class="float-left">
        @T("XcellenceIT.Plugin.ProductRibbons.Configure.Name")
    </h1>
    <div class="float-right">
        <a asp-action="Create" class="btn bg-blue">
            <i class="fas fa-plus-square"></i>
            @T("Admin.Common.AddNew")
        </a>
    </div>
</div>

<form asp-controller="ProductRibbonAdmin" asp-action="List" method="post">
    <section class="content">
        <div class="form-horizontal">
            <div class="cards-group">
                <div class="card card-default card-search">
                    <div class="card-body">
                        <div class="row search-row @(!hideSearchBlock ? "opened" : "")" data-hideAttribute="@hideSearchBlockAttributeName">
                            <div class="search-text">@T("Admin.Common.Search")</div>
                            <div class="icon-search"><i class="fas fa-search" aria-hidden="true"></i></div>
                            <div class="icon-collapse"><i class="far fa-angle-@(!hideSearchBlock ? "up" : "down")" aria-hidden="true"></i></div>
                        </div>

                        <div class="search-body @(hideSearchBlock ? "closed" : "")">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group row">
                                        <div class="col-md-4">
                                            <nop-label asp-for="@Model.StartDateUtc" />
                                        </div>
                                        <div class="col-md-8">
                                            <nop-editor asp-for="@Model.StartDateUtc" />
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <div class="col-md-4">
                                            <nop-label asp-for="@Model.EndDateUtc" />
                                        </div>
                                        <div class="col-md-8">
                                            <nop-editor asp-for="@Model.EndDateUtc" />
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group row">
                                        <div class="col-md-4">
                                            <nop-label asp-for="@Model.RibbonName" />
                                        </div>
                                        <div class="col-md-8">
                                            <nop-editor asp-for="@Model.RibbonName" />
                                        </div>
                                    </div>
                                    <div class="form-group row">
                                        <div class="col-md-4">
                                            <nop-label asp-for="@Model.Enabled" />
                                        </div>
                                        <div class="col-md-8">
                                            <nop-editor asp-for="@Model.Enabled" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="form-group row">
                                <div class="text-center col-12">
                                    <button type="button" id="search-productribbons" class="btn btn-primary btn-search"><i class="fas fa-search"></i>@T("Admin.Common.Search")</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="card card-default">
                    <div class="card-body">
                        @await Html.PartialAsync("Table", new DataTablesModel
                        {
                           Name = "log-grid",
                           UrlRead = new DataUrl("List", "ProductRibbonAdmin", null),
                           UrlDelete = new DataUrl("ProductRibbonDelete", "ProductRibbonAdmin", null),
                           SearchButtonId = "search-productribbons",
                           Length = Model.PageSize,
                           LengthMenu = Model.AvailablePageSizes,
                           Filters = new List<FilterParameter>
                            {
                                new FilterParameter(nameof(Model.RibbonName)),
                                new FilterParameter(nameof(Model.Enabled), typeof(bool)),
                                new FilterParameter(nameof(Model.StartDateUtc)),
                                new FilterParameter(nameof(Model.EndDateUtc))
                            },
                           ColumnCollection = new List<ColumnProperty>
                            {
                                new ColumnProperty(nameof(ProductRibbonModel.RibbonName))
                                {
                                    Title = T("XcellenceIT.Plugin.ProductRibbons.RibbonName").Text,
                                    Width = "50"
                                },
                                    new ColumnProperty(nameof(ProductRibbonModel.StartDateUtc))
                                {
                                    Title = T("XcellenceIT.Plugin.ProductRibbons.StartDateUtc").Text,
                                    Width = "50",
                                    Render = new RenderDate()
                                },
                                new ColumnProperty(nameof(ProductRibbonModel.EndDateUtc))
                                {
                                        Title = T("XcellenceIT.Plugin.ProductRibbons.EndDateUtc").Text,
                                    Width = "100",
                                    Render = new RenderDate()
                                },
                                new ColumnProperty(nameof(ProductRibbonModel.DisplayOrder))
                                {
                                    Title = T("XcellenceIT.Plugin.ProductRibbons.DisplayOrder").Text,
                                    Width = "100",
                                },
                                new ColumnProperty(nameof(ProductRibbonModel.Enabled))
                                {
                                    Title = T("XcellenceIT.Plugin.ProductRibbons.Enabled").Text,
                                    Width = "100",
                                    Render= new RenderBoolean()
                                },
                                new ColumnProperty(nameof(ProductRibbonModel.Id))
                                {
                                    Title = T("Admin.Common.Edit").Text,
                                    Width = "100",
                                    ClassName =  NopColumnClassDefaults.Button,
                                    Render = new RenderButtonEdit(new DataUrl("Edit"))
                                },
                                new ColumnProperty(nameof(ProductRibbonModel.Id))
                                {
                                Title = T("Admin.Common.Delete").Text,
                                ClassName = NopColumnClassDefaults.Button,
                                Render = new RenderButtonRemove(T("Admin.Common.Delete").Text),
                                Width = "100"
                                }
                            }
                        })
                    </div>
                </div>
            </div>
        </div>

        @await Component.InvokeAsync("ProductRibbonsSearchVersion")
    </section>
</form>