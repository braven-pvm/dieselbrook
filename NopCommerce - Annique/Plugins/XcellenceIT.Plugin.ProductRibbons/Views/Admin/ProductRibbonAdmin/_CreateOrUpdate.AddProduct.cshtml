@model ProductRibbonModel

@if (Model.Id > 0)
{
    <div class="card-body">
        @await Html.PartialAsync("Table", new DataTablesModel
    {
        Name = "products-grid",
        UrlRead = new DataUrl("ProductList", "ProductRibbonAdmin", new RouteValueDictionary { [nameof(Model.productRibbonSearchModel.RibbonId)] = Model.productRibbonSearchModel.RibbonId }),
        UrlDelete = new DataUrl("ProductDelete", "ProductRibbonAdmin", null),
        Length = Model.productRibbonSearchModel.PageSize,
        LengthMenu = Model.productRibbonSearchModel.AvailablePageSizes,

        ColumnCollection = new List<ColumnProperty>
            {
            new ColumnProperty(nameof(Model.productMappingModel.ProductName))
            {
            Title = T("Admin.Catalog.Categories.Products.Fields.Product").Text,
            Width = "300",
            EditType = EditType.String
            },
            new ColumnProperty(nameof(Model.productMappingModel.Published))
            {
            Title = T("Admin.Catalog.Products.Fields.Published").Text,
            Width = "250",
            EditType = EditType.Number,
            Render = new RenderBoolean()
            },

            new ColumnProperty(nameof(Model.productMappingModel.Id))
            {
            Title = T("Admin.Common.Delete").Text,
            ClassName = NopColumnClassDefaults.Button,
            Render = new RenderButtonRemove(T("Admin.Common.Delete").Text),
            Width = "100"
            }
            }
    })
    </div>
    <div class="card-footer">
        <button type="submit" id="btnAddNewProduct"
                onclick="javascript:OpenWindow('@(Url.Action("ProductAddPopup", "ProductRibbonAdmin" , new { ribbonId=Model.Id, btnId="btnRefreshProducts" , formId="Productribbon-form" }))', 800, 750, true); return false;" class="btn btn-primary">
            @T("XcellenceIT.Plugin.ProductRibbons.AddNewProduct")
        </button>
        <input type="submit" id="btnRefreshProducts" class="btn btn-default" style="display: none" />

        <script>
            $(document).ready(function () {
                $('#btnRefreshProducts').click(function () {
                    //refresh grid
                    updateTable('#products-grid');

                    //return false to don't reload a page
                    return false;
                });
            });
        </script>
    </div>
}
else
{
    <div class="card card-default">
        <div class="card-body">
            @T("XcellenceIT.Plugin.ProductRibbons.tab.Products.SaveBeforeEdit")
        </div>
    </div>
}